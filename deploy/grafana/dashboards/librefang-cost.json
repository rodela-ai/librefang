          "uid": "librefang-prometheus"
        },
        "query": "label_values(librefang_tokens, agent)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "multi": true,
        "sort": 1
      },
      {
        "name": "provider",
        "label": "Provider",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "librefang-prometheus"
        },
        "query": "label_values(librefang_tokens, provider)",
        "refresh": 2,
        "includeAll": true,
